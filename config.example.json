{
  "notifier": {
    "_comment_type": "Which push backend to use: 'bark' (iPhone/Apple Watch), 'pushover', or 'ntfy'. Only the fields for the chosen type matter; the others can stay as placeholders.",
    "type": "bark",
    "bark_key": "YOUR_BARK_KEY",
    "bark_server": "https://api.day.app",
    "group": "AgentWatch",
    "level": "timeSensitive",
    "_comment_pushover": "type=pushover: create an app at pushover.net/apps for pushover_token; pushover_user is the user key on your dashboard. pushover_priority is optional (-2..2, omit/0 = normal). pushover_server only changes for self-hosted setups.",
    "pushover_token": "YOUR_PUSHOVER_TOKEN",
    "pushover_user": "YOUR_PUSHOVER_USER",
    "pushover_server": "https://api.pushover.net",
    "pushover_priority": 0,
    "_comment_ntfy": "type=ntfy: ntfy_topic is your subscribed topic. ntfy_server defaults to public https://ntfy.sh (set your self-hosted URL otherwise). ntfy_priority 1-5 (5=max, default 4). ntfy_token only needed for protected/private topics (Bearer auth).",
    "ntfy_topic": "YOUR_NTFY_TOPIC",
    "ntfy_server": "https://ntfy.sh",
    "ntfy_priority": 4,
    "ntfy_token": "YOUR_NTFY_TOKEN"
  },
  "risk_policy": {
    "dangerous_commands": [
      "rm -rf",
      "sudo",
      "git push",
      "git reset --hard",
      "git clean",
      "chmod",
      "chown",
      "dd ",
      "mkfs",
      "killall"
    ],
    "dangerous_paths": [
      ".env",
      ".ssh",
      "id_rsa",
      "id_ed25519",
      ".git",
      "secrets",
      "token",
      "credentials",
      "private_key"
    ],
    "protected_paths": [],
    "dangerous_file_extensions": [
      ".pem",
      ".key"
    ]
  },
  "task_boundary": {
    "enabled": true,
    "task_name": "default",
    "allowed_paths": [],
    "forbidden_paths": [],
    "forbidden_keywords": [
      "training pipeline",
      "raw data",
      "delete dataset",
      "rewrite architecture"
    ]
  },
  "failure_policy": {
    "consecutive_failure_threshold": 3
  },
  "notification_policy": {
    "mode": "actionable",
    "_comment": "actionable = only push when user interaction is needed; verbose = push every event",
    "notify_on_task_done": true,
    "notify_on_interactive_attention": true,
    "notify_on_pretooluse": false,
    "notify_on_danger": false,
    "notify_on_drift": false,
    "notify_on_failure": false,
    "log_silent_events": true
  },
  "approval_detection": {
    "enabled": true,
    "delay_seconds": 4,
    "candidate_tools": [
      "Bash",
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit"
    ],
    "timeout_watch_notify": false,
    "timeout_log_only": true,
    "cooldown_seconds": 30
  },
  "persona": {
    "enabled": true,
    "theme": "boss",
    "user_role": "总裁"
  }
}
